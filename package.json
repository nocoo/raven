{
  "name": "raven",
  "version": "1.7.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:proxy": "bun run --filter '@raven/proxy' dev",
    "dev:dashboard": "bun run --filter dashboard dev",
    "test": "bun run --filter '@raven/proxy' test",
    "test:all": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:perf": "bun run --filter '@raven/proxy' test:perf",
    "gate:security": "bun run scripts/gate-security.ts",
    "test:ui": "bun run scripts/run-playwright.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/proxy/src/**/*.ts": "eslint --config eslint.config.js --max-warnings=0",
    "packages/dashboard/src/**/*.{ts,tsx}": "eslint --config eslint.config.js --max-warnings=0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.57.2"
  },
  "overrides": {
    "flatted": ">=3.4.2",
    "brace-expansion": ">=5.0.5",
    "vite": "^8.0.5"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "micromatch": "^4.0.8",
    "next": "^16.2.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.1"
  }
}
