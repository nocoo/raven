# raven dashboard — environment variables
# Copy to .env.local and adjust as needed:
#   cp .env.example .env.local

# --- Local mode ---
# If any of GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, or NEXTAUTH_SECRET is missing,
# the dashboard runs without authentication — suitable for local-only usage.
# Set the Google OAuth vars below to enable login.

# --- NextAuth (required for Google OAuth) ---

# Base URL for NextAuth (must match your browser URL).
NEXTAUTH_URL=http://localhost:7032

# Session signing secret. Generate one with:
#   openssl rand -base64 32
# Required for Google OAuth, not needed for local mode.
NEXTAUTH_SECRET=

# --- Google OAuth (optional for local use) ---
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $NEXTAUTH_URL/api/auth/callback/google

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Access control ---

# Comma-separated list of allowed email addresses.
# Leave empty to allow all authenticated users.
ALLOWED_EMAILS=

# --- Proxy connection ---

# URL where the raven proxy is running.
RAVEN_PROXY_URL=http://localhost:7033

# Dashboard → Proxy management credential.
# Proxy reads this natively — accepts it for /api/* and /ws/logs.
# Falls back to RAVEN_API_KEY if not set.
RAVEN_INTERNAL_KEY=

# --- Cookies ---

# Set to "true" to force secure cookies (HTTPS).
# Auto-enabled when NEXTAUTH_URL starts with https:// or NODE_ENV=production.
USE_SECURE_COOKIES=
