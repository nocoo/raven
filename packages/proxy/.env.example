# raven proxy — environment variables
# Copy to .env.local and adjust as needed:
#   cp .env.example .env.local

# Proxy listen port
RAVEN_PORT=7024

# API key for authenticating AI API requests (Claude Code, Cursor, etc.).
# Also accepted by dashboard management endpoints.
# If empty, clients must use a DB-managed key created via dashboard.
RAVEN_API_KEY=

# Dashboard → Proxy management credential.
# Proxy reads this natively. Dashboard sends it as Bearer token for
# /api/* and /ws/logs endpoints. Not accepted by AI API routes.
# Required after creating the first DB key (dev mode exits).
RAVEN_INTERNAL_KEY=

# Path to persist the GitHub OAuth token obtained via Device Flow.
RAVEN_TOKEN_PATH=data/github_token

# Minimum log level: debug | info | warn | error
RAVEN_LOG_LEVEL=info

# Public base URL returned by /api/connection-info.
# Leave empty to default to http://localhost:$RAVEN_PORT.
# Set this when running behind a reverse proxy or custom hostname.
RAVEN_BASE_URL=
