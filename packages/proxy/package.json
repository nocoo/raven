  },
  "dependencies": {
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "socks": "^2.8.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.9"
  }
}
